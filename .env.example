# ─── Qdrant — LOCAL (Docker) ────────────────────────────────────────────────
# Dùng khi chạy local qua docker-compose
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ─── Qdrant Cloud (Teamwork) ─────────────────────────────────────────────────
# Đăng ký free tại: https://cloud.qdrant.io
# Sau khi tạo cluster, điền URL và API key vào đây
# Khi dùng Cloud: để trống QDRANT_HOST hoặc xóa dòng QDRANT_HOST
QDRANT_URL=https://xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx.us-east4-0.gcp.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_cloud_api_key_here

# ─── LLM API Keys ───────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
